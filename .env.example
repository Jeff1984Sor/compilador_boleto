# Chave da API OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Modelo OpenAI (gpt-4o-mini eh barato e suficiente; gpt-4o mais capaz)
OPENAI_MODEL=gpt-4o-mini

# DPI da imagem gerada do PDF antes de enviar pro Vision (default 120)
OPENAI_PDF_DPI=120

# Detail do Vision: low (~85 tokens/img, cabe no Tier 1) ou high (ate ~25k tokens)
OPENAI_IMAGE_DETAIL=low

# Serializa as chamadas (1 por vez) para sobreviver ao TPM apertado do Tier 1.
# Suba de tier e ponha 0 para liberar paralelismo.
OPENAI_SERIALIZE=1

# Quantos retries adicionais em erro 429 (alem dos 6 automaticos do SDK)
OPENAI_MAX_429_RETRIES=10

# Porta HTTP em que o app escuta
PORT=9000

# Tamanho maximo do upload total, em MB (default 500)
MAX_UPLOAD_MB=500

# Tempo (em minutos) que os arquivos de uma sessao ficam disponiveis para preview/download
SESSION_TTL_MINUTES=30

# Diretorio raiz para arquivos temporarios de sessao
SESSIONS_DIR=/tmp/conciliador_sessions

# Chave secreta do Flask (gere uma string aleatoria longa)
FLASK_SECRET_KEY=troque-isto-por-uma-string-aleatoria-longa

# Quantas chamadas paralelas a IA (so vale quando OPENAI_SERIALIZE=0)
AI_MAX_WORKERS=6
