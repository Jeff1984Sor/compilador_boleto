# Chave da API OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Modelo OpenAI usado para extracao (gpt-4o-mini = barato e bom; gpt-4o = mais caro e mais preciso)
OPENAI_MODEL=gpt-4o-mini

# Detail level das imagens enviadas ao Vision: low (~85 tokens, default) ou high (~25k tokens, mais preciso)
# Conta Tier 1 (200k TPM) so cabe low. Suba para high apos atingir Tier 2.
OPENAI_IMAGE_DETAIL=low

# DPI da renderizacao do PDF -> PNG antes de enviar. 120 eh suficiente para "low".
OPENAI_PDF_DPI=120

# Quantas chamadas paralelas ao Vision (default 6).
# Em Tier 1 mantenha em 6 mas com OPENAI_SERIALIZE=1 (default) que serializa de fato.
AI_MAX_WORKERS=6

# Workaround para Tier 1 da OpenAI (TPM apertado): "1" serializa todas as chamadas
# (uma de cada vez) com backoff exponencial. Quando subir para Tier 2+, troque para "0"
# que volta a paralelismo real. Default "1".
OPENAI_SERIALIZE=1

# Quantos retries em 429 antes de desistir (default 10). Backoff exponencial com jitter
# ou usando o "try again in Xs" que a OpenAI retorna no erro.
OPENAI_MAX_429_RETRIES=10

# Porta HTTP em que o app escuta
PORT=9000

# Tempo (em minutos) que os arquivos de uma sessao ficam disponiveis para preview/download
SESSION_TTL_MINUTES=30

# Diretorio raiz para arquivos temporarios de sessao
SESSIONS_DIR=/tmp/conciliador_sessions

# Chave secreta do Flask (gere uma string aleatoria longa)
FLASK_SECRET_KEY=troque-isto-por-uma-string-aleatoria-longa
